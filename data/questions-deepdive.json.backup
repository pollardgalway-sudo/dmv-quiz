    },
    "options": {
      "A": { "en": "No, if there are 4 or more lanes.", "zh-Hans": "不需要，如果有 4 条或更多车道。", "zh-Hant": "不需要，如果有 4 條或更多車道。" },
      "B": { "en": "Yes, you must stop.", "zh-Hans": "是的，您必须停车。", "zh-Hant": "是的，您必須停車。" },
