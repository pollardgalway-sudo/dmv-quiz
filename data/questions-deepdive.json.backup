  {
    "id": 76,
    "category": "Literacy",
    "question": {
      "en": "At what age can a minor legally use a cell phone while driving?",
      "zh-Hans": "未成年人在多大年龄可以在驾车时合法使用手机？",
      "zh-Hant": "未成年人在多大年齡可以在駕車時合法使用手機？"
    },
    "options": {
      "A": { "en": "16, if using hands-free.", "zh-Hans": "16 岁，如果使用免提。", "zh-Hant": "16 歲，如果使用免提。" },
      "B": { "en": "18, for emergency calls only.", "zh-Hans": "18 岁，仅限紧急电话。", "zh-Hant": "18 歲，僅限緊急電話。" },
      "C": { "en": "Never until they turn 18, even if hands-free.", "zh-Hans": "满 18 岁之前绝不可以，即使是免提也不行。", "zh-Hant": "滿 18 歲之前絕不可以，即使是免提也不行。" }
    },
    "answer": "C",
    "explanation": {
      "en": "Drivers under 18 are prohibited from using any wireless device while driving, even in hands-free mode.",
      "zh-Hans": "18岁以下的驾驶员在开车时严禁使用任何无线通讯设备，唯一的例外是拨打真正的紧急求助电话。",
      "zh-Hant": "18歲以下的駕駛員在開車時嚴禁使用任何無線通訊設備，唯一的例外是撥打真正的緊急求助電話。"
    },
    "dmv_ref": {
      "page": "86",
      "section": "Section 8: Distracted Driving",
