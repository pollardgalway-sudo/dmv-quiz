      "analysis_zh-Hant": "手冊解析：針對青少年的法規比成年人更嚴格，旨在培養專注力。"
    }
  },
  {
    "id": 77,
    "category": "Literacy",
    "question": {
      "en": "If your accelerator pedal gets stuck, you should:",
      "zh-Hans": "如果您的油门踏板卡住了，您应该：",
      "zh-Hant": "如果您的油門踏板卡住了，您應該："
    },
    "options": {
      "A": { "en": "Turn off the ignition immediately.", "zh-Hans": "立即关闭点火开关。", "zh-Hant": "立即關閉點火開關。" },
      "B": { "en": "Shift to neutral and apply the brakes.", "zh-Hans": "换入空档并踩刹车。", "zh-Hant": "換入空檔並踩剎車。" },
      "C": { "en": "Pull the emergency brake.", "zh-Hans": "拉动紧急制动器。", "zh-Hant": "拉動緊急制動器。" }
    },
    "answer": "B",
    "explanation": {
      "en": "Shifting to neutral cuts power to the wheels. Do not turn off the engine as it may lock the steering.",
      "zh-Hans": "换空档可以切断动力输出。不要熄火，因为熄火会导致转向助力消失或方向盘锁死。",
      "zh-Hant": "換空檔可以切斷動力輸出。不要熄火，因為熄火會導致轉向助力消失或方向盤鎖死。"
    },
    "dmv_ref": {
      "page": "91",
      "section": "Section 8: Vehicle Failures",
      "analysis_zh-Hans": "手册解析：安全停稳后，再关闭引擎并寻求救援。",
      "analysis_zh-Hant": "手冊解析：安全停穩後，再關閉引擎並尋求救援。"
    }
  },
  {
    "id": 78,
    "category": "Literacy",
    "question": {
      "en": "When can you pass on the right?",
      "zh-Hans": "什么时候可以从右侧超车？",
      "zh-Hant": "什麼時候可以從右側超車？"
    },
    "options": {
      "A": { "en": "On a road with two or more lanes in your direction.", "zh-Hans": "在您行驶方向有两条或更多车道的道路上。", "zh-Hant": "在您行駛方向有兩條或更多車道的道路上。" },
      "B": { "en": "To pass a slow driver in the fast lane.", "zh-Hans": "为了超越快速车道上的慢车。", "zh-Hant": "為了超越快速車道上的慢車。" },
      "C": { "en": "If the shoulder is wide enough.", "zh-Hans": "如果路肩足够宽。", "zh-Hant": "如果路肩足夠寬。" }
    },
    "answer": "A",
    "explanation": {
      "en": "You may pass on the right only when there are multiple lanes or the driver ahead is turning left.",
      "zh-Hans": "只有在同向多车道，或者前方车辆明确表示要左转且右侧有空间时，才可从右侧通过。",
      "zh-Hant": "只有在同向多車道，或者前方車輛明確表示要左轉且右側有空間時，才可從右側通過。"
    },
    "dmv_ref": {
      "page": "42",
      "section": "Section 7: Lanes",
      "analysis_zh-Hans": "手册警示：绝不可以驶离路面（如进入土路或路肩）去右侧超车。",
      "analysis_zh-Hant": "手冊警示：絕不可以駛離路面（如進入土路或路肩）去右側超車。"
    }
  },
