[
  {
    "id": 71,
    "category": "Literacy",
    "question": {
      "en": "On a mountain road where two vehicles cannot pass, which vehicle has the right-of-way?",
      "zh-Hans": "在两车无法避让的山路上，哪辆车拥有优先权？",
      "zh-Hant": "在兩車無法避讓的山路上，哪輛車擁有優先權？"
    },
    "options": {
      "A": { "en": "The vehicle traveling uphill.", "zh-Hans": "上坡行驶的车辆。", "zh-Hant": "上坡行駛的車輛。" },
      "B": { "en": "The vehicle traveling downhill.", "zh-Hans": "下坡行驶的车辆。", "zh-Hant": "下坡行駛的車輛。" },
      "C": { "en": "The heavier vehicle.", "zh-Hans": "较重的车辆。", "zh-Hant": "較重的車輛。" }
    },
    "answer": "A",
    "explanation": {
      "en": "The vehicle traveling uphill has more control when backing up than a vehicle descending.",
      "zh-Hans": "上坡车拥有优先权，下坡车应倒车避让，因为下坡车倒车时控制力更好且更安全。",
      "zh-Hant": "上坡車擁有優先權，下坡車應倒車避讓，因為下坡車倒車時控制力更好且更安全。"
    },
    "dmv_ref": {
      "page": "35",
      "section": "Section 7: Right-of-Way Rules",
      "analysis_zh-Hans": "手册规定：下坡车必须倒车，直到上坡车可以驶过为止。",
      "analysis_zh-Hant": "手冊規定：下坡車必須倒車，直到上坡車可以駛過為止。"
    }
  },
  {
    "id": 72,
    "category": "Literacy",
    "question": {
      "en": "2026 Update: When using a 'Level 2' driver assistance system (like Autopilot), the driver:",
      "zh-Hans": "2026年更新：当使用“2级”辅助驾驶系统（如自动辅助驾驶）时，驾驶员：",
      "zh-Hant": "2026年更新：當使用「2級」輔助駕駛系統（如自動輔助駕駛）時，駕駛員："
    },
    "options": {
      "A": { "en": "May sleep while the car is driving.", "zh-Hans": "可以在车辆行驶时睡觉。", "zh-Hant": "可以在車輛行駛時睡覺。" },
      "B": { "en": "Must remain alert and keep hands near the wheel.", "zh-Hans": "必须保持警觉，双手靠近方向盘。", "zh-Hant": "必須保持警覺，雙手靠近方向盤。" },
      "C": { "en": "Can watch videos on the dashboard.", "zh-Hans": "可以在中控屏幕上看视频。", "zh-Hant": "可以在中控屏幕上看視頻。" }
    },
    "answer": "B",
    "explanation": {
      "en": "Drivers are legally responsible for the vehicle even when driver assistance systems are active.",
      "zh-Hans": "即使开启了辅助驾驶，驾驶员仍对车辆行为负全责，必须随时准备接管。",
      "zh-Hant": "即使開啟了輔助駕駛，駕駛員仍對車輛行為負全責，必須隨時準備接管。"
