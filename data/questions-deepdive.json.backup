      "zh-Hans": "什么是“水漂现象（Hydroplaning）”？",
      "zh-Hant": "什麼是「水漂現象（Hydroplaning）」？"
    },
    "options": {
      "A": { "en": "When tires lose contact with the road and slide on a layer of water.", "zh-Hans": "当轮胎失去与路面的接触，在水层上滑动。", "zh-Hant": "當輪胎失去與路面的接觸，在水層上滑動。" },
      "B": { "en": "When the engine stalls in deep water.", "zh-Hans": "当引擎在深水中熄火。", "zh-Hant": "當引擎在深水中熄火。" },
      "C": { "en": "When your brakes get wet and fail.", "zh-Hans": "当刹车受潮失灵。", "zh-Hant": "當剎車受潮失靈。" }
